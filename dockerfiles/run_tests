FROM alpine:3.23.4 AS build
RUN apk add meson libgcc musl-dev gcc g++ upx linux-headers
COPY . /code
RUN mkdir /build
WORKDIR /code
RUN --mount=type=cache,target=/build LDFLAGS='-static' meson setup /build/code --default-library static --buildtype=release --wipe
WORKDIR /build/code
RUN  --mount=type=cache,target=/build meson test -v
